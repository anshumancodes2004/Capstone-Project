@login_required("admin")
def delete_exam(exam_id):
    conn   = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("DELETE answers FROM answers JOIN questions ON answers.question_id=questions.id WHERE questions.exam_id=%s", (exam_id,))
