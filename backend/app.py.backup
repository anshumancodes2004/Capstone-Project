@app.route("/delete_student/<int:id>")
@login_required("admin")
def delete_student(id):

    conn = get_db_connection()
    cursor = conn.cursor()

    # pehle answers delete
    cursor.execute("DELETE FROM answers WHERE student_id=%s", (id,))

